# ==========================================
# Root Gitignore for Smart Attendance System
# ==========================================

# -----------------
# OS & IDE Caches
# -----------------
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ IDEA
*.iml
*.ipr
*.iws
.idea/
.idea_modules/

# VS Code
.vscode/

# -----------------
# Frontend (Flutter)
# -----------------
frontend/.dart_tool/
frontend/.flutter-plugins
frontend/.flutter-plugins-dependencies
frontend/.pub-cache/
frontend/.pub/
frontend/build/
frontend/coverage/
frontend/.config/
frontend/lib/firebase_options.dart

# Android build outputs
frontend/android/app/debug/
frontend/android/app/profile/
frontend/android/app/release/

# iOS build outputs
frontend/ios/Flutter/.last_build_id
frontend/ios/DerivedData/

# -----------------
# Backend (FastAPI / Python)
# -----------------
backend/__pycache__/
backend/venv/
backend/.venv/
backend/env/
backend/ENV/
backend/bin/
backend/lib/
backend/include/

# Local databases & user data (Crucial for privacy)
backend/embeddings.json
backend/profile_photos/

# Security: Ignore Firebase service account credentials/keys if placed in backend
backend/*firebase-adminsdk*.json
backend/*.credentials.json
backend/service-account.json
backend/secrets.json
backend/.env
